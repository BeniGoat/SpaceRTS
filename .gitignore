# =========================================================================
# UNITY IGNORES
# =========================================================================
# Unity generates these directories automatically on open/compile.
[Aa]sset/[Ss]cenes/[Ee]ditModeTestData/
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/

# Unity Addressables cache
[Aa]ssets/[Aa]ddressable[Aa]sset[Dd]ata/*/*.bin*

# Unity Asset Store packages (imported packages are copied to Packages/)
[Aa]ssets/[Aa]sset[Ss]tore[Tt]ools*

# =========================================================================
# VISUAL STUDIO & C# SOLUTION IGNORES
# =========================================================================
# VS user-specific settings, cache, and build files
.vs/
.idea/
.vscode/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.VC.db

# C# build outputs
bin/
obj/

# =========================================================================
# OS & SYSTEM CLUTTER
# =========================================================================
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
[Dd]esktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Trashes

# =========================================================================
# BUILDS & EXECUTABLES
# =========================================================================
*.apk
*.aab
*.unitypackage
*.app